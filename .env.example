# ============================================================
# Elkhedr Orca Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Required: OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Logging level (debug, info, warn, error)
# Default: info
ORCA_LOG_LEVEL=info

# Optional: Database configuration
# Database type: sqlite (default), postgresql, postgres, pg
ORCA_DB_TYPE=sqlite

# SQLite configuration (default)
# ORCA_DB_PATH=./data/orca.db
# ORCA_DB_READONLY=false

# PostgreSQL configuration (for production)
# Option 1: Connection string
# ORCA_DB_URL=postgresql://user:password@localhost:5432/orca

# Option 2: Individual components
# ORCA_DB_HOST=localhost
# ORCA_DB_PORT=5432
# ORCA_DB_NAME=orca
# ORCA_DB_USER=orca_user
# ORCA_DB_PASSWORD=your_secure_password
# ORCA_DB_SSL=false

# PostgreSQL connection pooling
# ORCA_DB_POOL_MIN=2
# ORCA_DB_POOL_MAX=10
# ORCA_DB_POOL_IDLE_TIMEOUT=30000
# ORCA_DB_POOL_ACQUIRE_TIMEOUT=60000
# ORCA_DB_DEBUG=false

# Optional: Redis URL for caching and queues
# Example: redis://localhost:6379
# For TLS: rediss://username:password@host:6380
ORCA_REDIS_URL=
# Redis cache TTL in seconds (default: 300)
# ORCA_REDIS_TTL=300
# Redis key prefix (default: orca)
# ORCA_REDIS_KEY_PREFIX=orca
# Enable TLS for Redis (default: false)
# ORCA_REDIS_TLS_ENABLED=false

# Optional: Server configuration (for web dashboard)
ORCA_PORT=3000
ORCA_HOST=0.0.0.0

# Optional: Backup configuration
# Backup directory (default: ./backups/db)
# ORCA_BACKUP_DIR=./backups/db
# Backup retention in days (default: 30)
ORCA_BACKUP_RETENTION_DAYS=30
# Backup schedule cron expression (default: daily at 3 AM)
# ORCA_BACKUP_SCHEDULE=0 3 * * *
# PostgreSQL password for pg_dump/pg_restore
# ORCA_DB_PASSWORD=

# Optional: JWT Secret for authentication (min 32 chars)
# Generate with: openssl rand -base64 32
ORCA_JWT_SECRET=

# Optional: Sandbox mode (true/false)
# When true, restricts file operations to sandbox directory
ORCA_SANDBOX=true

# Optional: API retry configuration
ORCA_MAX_RETRIES=3
ORCA_TIMEOUT=60000

# Optional: Model registry and routing
ORCA_MODEL_HEALTH_INTERVAL_MS=60000
ORCA_MODEL_ROUTING_STRATEGY=balanced
ORCA_MODEL_MAX_FALLBACKS=3
ORCA_MODEL_LATENCY_BUDGET_MS=30000
ORCA_MODEL_FAILURE_THRESHOLD=1

# Optional: Local model servers (Ollama / LM Studio)
# Set ORCA_LOCAL_MODEL_ENABLED=true to use local models with automatic cloud fallback
# Priority modes: local-first (prefer local), cloud-first (prefer cloud), cost-optimal
# OLLAMA_URL=http://localhost:11434
# LMSTUDIO_URL=http://localhost:1234
# ORCA_LOCAL_MODEL_ENABLED=false
# ORCA_LOCAL_MODEL_PRIORITY=local-first

# Optional: Analytics settings
ORCA_ANALYTICS_ENABLED=true
ORCA_ANALYTICS_RETENTION_DAYS=30

# Optional: Feature flags
ORCA_MCP_ENABLED=true
ORCA_SWARM_ENABLED=true

# Optional: OAuth providers (for web dashboard)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
