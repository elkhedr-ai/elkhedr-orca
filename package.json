{
  "name": "elkhedr-orca",
  "version": "1.1.0",
  "description": "Multi-Agent Orchestration System with 100 specialized AI agents",
  "main": "src/index.js",
  "bin": {
    "orca": "src/index.js",
    "mcp-orca": "src/mcp-server.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node src/index.js",
    "tui": "node src/tui.js",
    "mcp": "node src/mcp-server.js",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "lint": "echo 'Linting not configured yet'",
    "health": "node -e \"require('./src/core.js'); console.log('✓ Core module loads successfully')\"",
    "version": "node -e \"console.log(require('./package.json').version)\"",
    "db:migrate": "node -e \"require('./src/db/init.js').runMigrations('latest').catch(console.error)\"",
    "db:migrate:down": "node -e \"require('./src/db/init.js').runMigrations('down').catch(console.error)\"",
    "db:migrate:rollback": "node -e \"require('./src/db/init.js').runMigrations('rollback').catch(console.error)\"",
    "db:migrate:status": "node -e \"require('./src/db/init.js').runMigrations('status').catch(console.error)\"",
    "db:migrate:make": "node -e \"const name = process.argv[2]; if (!name) { console.error('Usage: npm run db:migrate:make <name>'); process.exit(1); } require('./src/db/init.js').createMigration(name).catch(console.error)\"",
    "db:backup": "bash scripts/backup.sh",
    "db:restore": "bash scripts/restore.sh",
    "db:backup:list": "ls -lh backups/db/ 2>/dev/null || echo 'No backups found'"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "openrouter",
    "mcp",
    "cli",
    "automation"
  ],
  "author": "Elkhedr",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@clack/prompts": "^1.3.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@graphql-tools/schema": "^10.0.33",
    "@graphql-tools/utils": "^11.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "chromium": "^3.0.3",
    "cli-cursor": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "enquirer": "^2.4.1",
    "fastify": "^5.8.5",
    "form-data": "^4.0.0",
    "gradient-string": "^2.0.2",
    "graphql": "^16.14.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.8",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "ora": "^5.4.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer-core": "^24.43.0",
    "react-flow-renderer": "^10.3.17",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "terminal-size": "^4.0.1",
    "word-wrap": "^1.2.5",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "db-migrate": "^0.11.14",
    "db-migrate-sqlite3": "^1.0.2"
  }
}
